vector<int> topo;
vector<int> indeg(n,0);
for(int i=0;i<n;i++){
  for(it:adj[i]){
    indeg[it]++;
  }
}
queue<int> q;
for(int i=0;i<n;i++){
  if(indeg[i]==0) push to q;
}
while(!q.empty()){
  int t=q.front();
q.pop();
topo.push_back(t);
for(int k:adj[t]){
  indeg[k]--;
  if(indeg[k]==0) q.push(k);
}
}
return topo;
