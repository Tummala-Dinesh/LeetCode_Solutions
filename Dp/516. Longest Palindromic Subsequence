class Solution {
    vector<vector<int>> dp;
    int fun(string &s, int i, int j) {
        if(i>j) return 0;
        if(i==j) return 1;
        if(dp[i][j]!=-1) return dp[i][j];
        if(s[i]==s[j]){
            return 2+fun(s,i+1,j-1);
        }
        int one=0,two=0;
        one=fun(s,i+1,j);
        two=fun(s,i,j-1);
        return dp[i][j]=max(one,two);

    }

public:
    int longestPalindromeSubseq(string s) {
        int n = s.length();
        dp.assign(n, vector<int>(n, -1));
        return fun(s,0, n - 1);
    }
};
