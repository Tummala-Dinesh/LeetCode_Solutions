class Solution {
public:
    int widthOfBinaryTree(TreeNode* root) {
        if (!root) return 0;

        queue<pair<TreeNode*, long long>> q;
        q.push({root, 0});

        long long maxw = 0;

        while (!q.empty()) {
            int sz = q.size();

            long long mn = q.front().second; // minimum index of this level
            long long first = 0, last = 0;

            for (int i = 0; i < sz; i++) {
                auto [node, idx] = q.front();
                q.pop();

                idx -= mn; // normalize

                if (i == 0) first = idx;
                if (i == sz - 1) last = idx;

                if (node->left)
                    q.push({node->left, 2 * idx + 1});

                if (node->right)
                    q.push({node->right, 2 * idx + 2});
            }

            maxw = max(maxw, last - first + 1);
        }

        return (int)maxw;
    }
};
